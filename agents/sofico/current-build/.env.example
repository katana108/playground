# Sofi Configuration
# Copy this to .env and fill in your values

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key

# Agent SDK / OAuth (k8s subscription mode)
# CLAUDE_CONFIG_DIR=/home/sofi/.claude-config
# SOFI_AGENT_SDK_AUTH=subscription

# GitLab Integration
GITLAB_ACCESS_TOKEN=glpat-your-token
GITLAB_URL=https://gitlab.com

# Sofi Settings
SOFI_NAME=Sofi
SOFI_DEFAULT_SESSION_SIZE=15
SOFI_INTERLEAVING_ENABLED=true
